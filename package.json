{
  "name": "pixrunner",
  "version": "0.1.0",
  "private": true,
  "description": "PixiRunner — jeu de conquête de territoire IRL en temps réel (monorepo de projets indépendants)",
  "workspaces": [
    "protocol",
    "game-server",
    "client",
    "campaign-service",
    "merchant-portal"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:game": "npm -w game-server run dev",
    "dev:client": "npm -w client run dev",
    "dev:campaign": "npm -w campaign-service run dev",
    "dev:portal": "npm -w merchant-portal run dev"
  },
  "engines": {
    "node": ">=20"
  }
}
